# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Haiku 4.5 ($1/$5 per 1M) is ~1/3 the cost of Sonnet and plenty for grounded
# RAG Q&A. Swap to claude-sonnet-4-6 if you want maximum answer quality.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Embeddings ---
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- CORS ---
# Comma-separated list of allowed origins for the widget.
ALLOWED_ORIGINS=https://dannyredel.github.io,http://localhost:4000,http://localhost:4200,http://127.0.0.1:4200,http://127.0.0.1:4000

# --- Admin ---
# Protects POST /api/ingest. Invent any long random string.
ADMIN_API_KEY=generate-a-long-random-string

# --- Retrieval ---
TOP_K=5
CHUNK_TARGET_TOKENS=500
CHUNK_MAX_TOKENS=800

# --- Rate limiting ---
RATE_LIMIT_PER_MIN=20

# --- Cost guardrail ---
# Hard ceiling on total /api/chat requests per UTC day (all users). In-memory,
# resets on restart. Backstop against IP-rotating abuse; the real hard wall is
# the monthly spend limit you set on the API keys in the provider consoles.
DAILY_REQUEST_CAP=1000

# --- Paths ---
# Markdown source — path to the Quarto site's /knowledge folder (used by ingest).
KNOWLEDGE_DIR=../dannyredel.github.io/knowledge

# Pickle file holding {chunks, embeddings}. Written by ingest, read at startup.
# Commit this file to the repo so Railway serves it without re-ingesting.
INDEX_PATH=data/index.pkl
